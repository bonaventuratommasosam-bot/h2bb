# --- Runtime ---
PORT=40001
DATA_DIR=.
# Directory dati (strategy.json, wallet.json, risk-state, logs). Default: root progetto.

# --- Hyperliquid ---
MIN_NOTIONAL_USD=10
HL_TIMEOUT_MS=10000
# HYPEREVM_RPC=https://rpc.hyperliquid.xyz/evm

# --- Wallet encryption (obbligatoria in LIVE) ---
# Genera con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WALLET_ENCRYPTION_KEY=

# --- Telegram (alert proattivi) ---
TELEGRAM_BOT_TOKEN=
# ownerChatId va in wallet.json (non qui)

# --- LLM (opzionale; auto-detect se presente) ---
# LLM_PROVIDER=auto
# GROQ_API_KEY=
# GEMINI_API_KEY=
# OPENROUTER_API_KEY=
# DEEPSEEK_API_KEY=
# XAI_API_KEY=
# LLM_MODEL=
# LLM_TIMEOUT_MS=8000

# --- Loop ---
# PROACTIVE_CHECK_MINUTES=20
# PROACTIVE_MIN_MINUTES=25
# PROACTIVE_BRIEFING_HOUR=8
# TICK_TIMEOUT_MS=40000

# --- Hard caps (override ceiling risk-first; default già sicuri) ---
# HARD_CAP_RISK_PER_TRADE=1.0
# HARD_CAP_MAX_POSITION=25
# HARD_CAP_DAILY_LOSS=2
# HARD_CAP_DRAWDOWN=8
# HARD_CAP_CONSEC_LOSS=3
# HARD_CAP_MIN_SCORE_FLOOR=50

# --- Shadow learning ---
# SHADOW_TRADES_FOR_COMPARE=20
